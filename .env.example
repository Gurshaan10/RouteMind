# Database Configuration
POSTGRES_DB=routemind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend Configuration
DEBUG=True
OPENAI_API_KEY=your-openai-api-key-here
SESSION_SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Redis Configuration (auto-configured in docker-compose)
# REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO

# Cache Settings
CACHE_TTL_SECONDS=3600

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS_PER_SESSION=5

# Collaboration Settings
COLLAB_SESSION_TIMEOUT_MINUTES=120

# Celery Configuration (for background jobs)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
